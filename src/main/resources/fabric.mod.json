	"authors": [
		"AmedoNai"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/skystone-celestial-threat/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"amedonai.ss_celestial_threat.SkyStoneCelestialThreat"
		],
		"client": [
			"amedonai.ss_celestial_threat.client.SkyStoneCelestialThreatClient"
		],
		"fabric-datagen": [
			"amedonai.ss_celestial_threat.client.SkyStoneCelestialThreatDataGenerator"
		]
	},
	"mixins": [
		"skystone-celestial-threat.mixins.json",
